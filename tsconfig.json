{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": ["ES2022"],

        "rootDir": "./src",
        "outDir": "./js",

        "declaration": true,
        "declarationMap": false,
        "sourceMap": false,

        "strict": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true,

        "skipLibCheck": true,
        "esModuleInterop": true
    },
    "include": ["src"],
    "exclude": ["node_modules", "js"]
}
